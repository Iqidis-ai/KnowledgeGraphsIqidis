# Knowledge Graph System - Environment Variables

# Required
GEMINI_API_KEY=your-api-key

# Iqidis (for Extract from Documents - same DB as Iqidis app)
development_POSTGRES_URL=postgres://user:pass@host:5432/db?sslmode=require

# AWS (S3 document downloads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
